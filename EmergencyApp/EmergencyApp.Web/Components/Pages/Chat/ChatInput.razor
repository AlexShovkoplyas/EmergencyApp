@inject IJSRuntime JS
@implements IAsyncDisposable

<EditForm Model="@this" OnValidSubmit="@SendMessageAsync">
    <label class="input-box page-width">
        <textarea @ref="@textArea" @bind="@messageText" placeholder="Type your message..." rows="1"></textarea>

        <div class="tools">
            @if (speechAvailable)
            {
                <select class="lang-select"
                        disabled="@isListening"
                        title="Speech recognition language"
                        @bind="speechLanguage">
                    <option value="">Auto</option>
                    <option value="en-US">EN</option>
                    <option value="uk-UA">UA</option>
                    <option value="ru-RU">RU</option>
                    <option value="de-DE">DE</option>
                </select>
            }

            <button type="button"
                    class="mic-button @(isListening ? "listening" : "")"
                    title="@(isListening ? "Stop voice input" : speechAvailable ? "Start voice input" : "Voice input unavailable")"
                    disabled="@(isMicBusy || !speechAvailable)"
                    @onclick="ToggleListeningAsync">
                @if (isListening)
                {
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="tool-icon">
                        <path d="M8.25 4.5a3.75 3.75 0 1 1 7.5 0v8.25a3.75 3.75 0 1 1-7.5 0V4.5Z" />
                        <path d="M6 10.5a.75.75 0 0 1 .75.75v1.5a5.25 5.25 0 1 0 10.5 0v-1.5a.75.75 0 0 1 1.5 0v1.5a6.751 6.751 0 0 1-6 6.709v2.291h3a.75.75 0 0 1 0 1.5h-7.5a.75.75 0 0 1 0-1.5h3v-2.291a6.751 6.751 0 0 1-6-6.709v-1.5A.75.75 0 0 1 6 10.5Z" />
                    </svg>
                }
                else
                {
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="tool-icon">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 18.75a6 6 0 0 0 6-6v-1.5m-6 7.5a6 6 0 0 1-6-6v-1.5m6 7.5v3.75m-3.75 0h7.5M12 15.75a3 3 0 0 1-3-3V4.5a3 3 0 0 1 6 0v8.25a3 3 0 0 1-3 3Z" />
                    </svg>
                }
            </button>

            <button type="submit" title="Send" class="send-button">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="tool-icon">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 12 3.269 3.125A59.769 59.769 0 0 1 21.485 12 59.768 59.768 0 0 1 3.27 20.875L5.999 12Zm0 0h7.5" />
                </svg>
            </button>
        </div>
    </label>
</EditForm>

@code {
    private ElementReference textArea;
    private string? messageText;
    private IJSObjectReference? _module;
    private DotNetObjectReference<ChatInput>? _dotNetRef;
    private bool speechAvailable;
    private bool isListening;
    private bool isMicBusy;
    private string speechLanguage = "";

    [Parameter]
    public EventCallback<ChatMessage> OnSend { get; set; }

    public ValueTask FocusAsync()
        => textArea.FocusAsync();

    private async Task SendMessageAsync()
    {
        if (messageText is { Length: > 0 } text)
        {
            messageText = null;
            await OnSend.InvokeAsync(new ChatMessage(ChatRole.User, text));
        }
    }

    private async Task ToggleListeningAsync()
    {
        if (_module is null) return;

        if (isListening)
        {
            isMicBusy = true;
            await _module.InvokeVoidAsync("stopListening");
            isListening = false;
            isMicBusy = false;
        }
        else
        {
            isMicBusy = true;
            try
            {
                await _module.InvokeVoidAsync("startListening", speechLanguage);
                isListening = true;
            }
            catch (JSException ex)
            {
                Logger.LogError(ex, "Failed to start speech recognition.");
                isMicBusy = false;
                // Optionally show a user-friendly error message via a toast or alert
            }
            finally
            {
                isMicBusy = false;
            }
        }
    }

    [JSInvokable]
    public void OnSpeechRecognized(string text)
    {
        if (!string.IsNullOrWhiteSpace(text))
        {
            messageText = string.IsNullOrEmpty(messageText)
                ? text
                : messageText.TrimEnd() + " " + text;
            StateHasChanged();
        }
    }

    [JSInvokable]
    public void OnSpeechStopped()
    {
        isListening = false;
        isMicBusy = false;
        StateHasChanged();
    }

    [Inject] ILogger<ChatInput> Logger { get; set; } = default!;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                _dotNetRef = DotNetObjectReference.Create(this);
                // Cache-bust so browsers always load the latest JS.
                var ver = DateTime.UtcNow.Ticks.ToString();
                _module = await JS.InvokeAsync<IJSObjectReference>(
                    "import", $"./Components/Pages/Chat/ChatInput.razor.js?v={ver}");
                speechAvailable = await _module.InvokeAsync<bool?>("init", textArea, _dotNetRef) == true;
                if (speechAvailable)
                    StateHasChanged();
            }
            catch (JSDisconnectedException) { }
            catch (JSException ex)
            {
                Logger.LogWarning(ex, "Speech JS module failed to initialise.");
            }
        }
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            if (isListening && _module is not null)
            {
                await _module.InvokeVoidAsync("stopListening");
            }
        }
        catch (Exception)
        {
            // Ignore exceptions during disposal, especially JSDisconnectedException
        }

        _dotNetRef?.Dispose();
        
        try
        {
            if (_module is not null)
            {
                await _module.DisposeAsync();
            }
        }
        catch (Exception)
        {
            // Ignore exceptions during disposal
        }
    }
}
